# Copy this file to `.env.local` for local development secrets.

INSIGHT_HUB_LLM_BASE_URL="https://api.openai.com/v1"
INSIGHT_HUB_LLM_API_KEY="sk-..."
# OpenAI model options that fit this feature well:
# - gpt-5.4-mini
# - gpt-5-mini
# - gpt-4.1-mini
# - gpt-5.4
INSIGHT_HUB_LLM_MODEL="gpt-5.4-mini"
INSIGHT_HUB_LLM_TIMEOUT_SECONDS="30"
INSIGHT_HUB_LLM_MAX_RETRIES="1"
